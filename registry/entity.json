{
  "schema_version": "1.0",
  "type": "entity",
  "official_name": "Entity",
  "description": "Organizations, products, services, and platforms — stable identity anchors for things in the security ecosystem.",
  "purpose": "Identify vendors, products, and services when PURL or SPDX identifiers aren't applicable. Includes organizations (MITRE, Red Hat, Cisco), products (OpenShift, iOS, Firepower), and services. Entity match_nodes use literal patterns since names are fixed strings.",
  "format": "secid:entity/<namespace>/<name>[#subpath]",
  "examples": [
    "secid:entity/redhat.com/openshift",
    "secid:entity/mitre.org/cve",
    "secid:entity/cisco.com/ios"
  ],
  "notes": "Entity entries describe what organizations and their products are. They cross-reference other types via issues_type and issues_namespace fields — e.g., an entity's product links to the advisory namespace where its vulnerabilities are published.",
