{
  "schema_version": "1.0",
  "type": "reference",
  "official_name": "Reference",
  "description": "Documents, publications, research, and identifier systems that don't fit into other SecID types.",
  "purpose": "Reference documents and identifier systems. Includes academic papers (arXiv, DOI), RFCs, ISBNs, GitHub artifacts (commits, pull requests, issues, discussions), CSA publications, and government documents (executive orders).",
  "format": "secid:reference/<namespace>/<name>[#subpath]",
  "examples": [
    "secid:reference/arxiv.org/2303.08774",
    "secid:reference/doi.org/10.1145/3274694.3274708",
    "secid:reference/ietf.org/rfc#RFC9116",
    "secid:reference/github.com/commit#abc1234def5678"
  ],
  "notes": "The catch-all type for security-relevant documents that aren't advisories, weaknesses, TTPs, controls, disclosures, regulations, or entities. If something doesn't fit elsewhere, it belongs here.",
  "namespace_count": 29,
  "namespaces": [
    {
