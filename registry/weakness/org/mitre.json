          "patterns": [
            "^CWE-\\d+$"
          ],
          "description": "CWE identifier (e.g., CWE-79, CWE-1427). Covers views, categories, and weaknesses — all use the same ID format.",
          "weight": 100,
          "data": {
            "url": "https://cwe.mitre.org/data/definitions/{num}.html",
            "variables": {
              "num": {
                "extract": "^CWE-(\\d+)$",
                "description": "Numeric CWE ID (e.g., '79' from 'CWE-79')"
              }
            },
            "examples": [
              {
                "input": "CWE-79",
                "variables": {
