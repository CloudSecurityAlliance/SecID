{
  "schema_version": "2.0",
  "description": "Validation overlay: machine-readable patches against the cve.org CNAsList.json data we consume. Each entry asserts 'at this JMESPath field_path, the current value (current_value) is broken, here is why, and here is upstream tracking.' Read by scripts/apply-known-broken.py as the final pipeline step to inject _broken_* metadata into registry/disclosure/*.json. The script is idempotent: when an entry is removed (because upstream fixed it), re-running strips the annotations from any matching disclosure entry.",
  "applies_to": {
    "source": "https://github.com/CVEProject/cve-website/blob/main/src/assets/data/CNAsList.json",
    "format": "CNAsList.json",
    "path_dialect": "JMESPath",
    "note": "field_paths are relative to the CNAsList.json root array. Use a JMESPath library (e.g., jmespath in Python, jmespath.js) to evaluate them against the live CNAsList.json."
  },
  "audit_date": "2026-05-09",
  "audit_methodology": "Combined HTTP audit (httpx + Playwright + manual real-browser verification) and email validation (QuickEmailVerification + real Gmail bounce evidence). Full data: working-data/cve-org-url-audit/ and working-data/cna/.",
  "recheck_policy": {
    "mode": "report-only",
    "note": "Companion audit script (scripts/audit-known-broken.py, planned) walks this file and reports four buckets: (1) still-present-in-registry, (2) replaced-upstream (field_path now holds a different value — needs revalidation), (3) disappeared-upstream (orphan, candidate for removal), (4) stale (last_verified older than threshold). The audit script does NOT auto-reprobe URLs/emails; that remains a human-triggered Playwright/QEV pass."
  },
